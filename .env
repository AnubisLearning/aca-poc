# ─────────────────────────────────────────────────────────────────────────────
# ACA – Automated Canary Analysis  |  Environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local overrides. Docker Compose uses .env.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=aca
POSTGRES_PASSWORD=aca_secret
POSTGRES_DB=aca
DATABASE_URL=postgresql://aca:aca_secret@postgres:5432/aca

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Service URLs (used by api-gateway and inter-service calls) ────────────────
CONFIG_SERVICE_URL=http://config-service:8001
JOB_MANAGER_URL=http://job-manager:8004
RESULTS_SERVICE_URL=http://results-service:8005
METRICS_FETCHER_URL=http://metrics-fetcher:8002
ANALYSIS_ENGINE_URL=http://analysis-engine:8003
PROMETHEUS_URL=http://prometheus:9090

# ── UI ────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
